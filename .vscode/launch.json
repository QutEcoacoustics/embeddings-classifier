  "version": "0.2.0",
  "configurations": [
    
    
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Debug Tests",
      "type": "python",
      "request": "launch",
      "console": "integratedTerminal",
      "justMyCode": false,
      "purpose": ["debug-test"]
    },
    {
      "name": "Debug postprocess_from_ecosounds_1.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/postprocess_from_ecosounds_1.py",
      "args": [
        "--filelist", "{}",
        "--results_dir", "{}",
        "--output_file", "{}",
        "--exclude_class", "neg"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug stratify.py (bittern feb2026)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/stratify.py",
      "args": [
        "local_files/inference_results/bittern/runs/feb2026/results/1131/aggregated_batch_01/classifier_0/0_feb2026_aggregated.csv",
        "-o",
        "local_files/inference_results/bittern/runs/feb2026/results/1131/aggregated_batch_01/classifier_0/for_verification_01.csv"
      ],
      "console": "integratedTerminal"
    }
  ]
}